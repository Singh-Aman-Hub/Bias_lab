# Google Gemini API Key (optional — enables narrative report generation)
# Get yours at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_key_here

# CORS: set to 1 to allow all origins (development only)
# CORS_ALLOW_ALL=1

# ── Firebase Auth ──
# Used by firebase_auth.py to verify user ID tokens (no service account needed).
# FIREBASE_PROJECT_ID=your-firebase-project-id

# Set DISABLE_AUTH=1 to bypass auth locally (e.g. for the pytest suite).
# DISABLE_AUTH=0

# ── Firebase Admin Service Account ──
# Replaces firebase-admin.json — paste values from your service-account JSON.
# FIREBASE_SA_TYPE=service_account
# FIREBASE_SA_PROJECT_ID=your-firebase-project-id
# FIREBASE_SA_PRIVATE_KEY_ID=your-private-key-id
# FIREBASE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_SA_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_SA_CLIENT_ID=your-client-id
# FIREBASE_SA_AUTH_URI=https://accounts.google.com/o/oauth2/auth
# FIREBASE_SA_TOKEN_URI=https://oauth2.googleapis.com/token
# FIREBASE_SA_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
# FIREBASE_SA_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project.iam.gserviceaccount.com
# FIREBASE_SA_UNIVERSE_DOMAIN=googleapis.com
